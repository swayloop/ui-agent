{
  "name": "@swayloop/ui-agent",
  "version": "1.0.0",
  "description": "AI-native UI generation pipeline that works across Claude Code, Codex, Cursor, and Gemini CLI.",
  "type": "module",
  "bin": {
    "ui-agent": "dist/cli.js"
  },
  "files": [
    "dist",
    "templates",
    "README.md"
  ],
  "scripts": {
    "prepare": "husky",
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "pnpm build",
    "lint:commit": "commitlint --from=HEAD~1 --to=HEAD"
  },
  "packageManager": "pnpm@10.18.0",
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "ai",
    "ui",
    "design-system",
    "claude-code",
    "codex",
    "cursor",
    "shadcn",
    "storybook"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@swayloop/commitlint-config": "^0.2.0",
    "@types/node": "^22.10.0",
    "husky": "^9.1.7",
    "prettier": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "prettier": "@swayloop/prettier-config"
}
